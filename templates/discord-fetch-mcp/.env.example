# Required
DISCORD_BOT_TOKEN=

# Optional
MCP_SERVER_NAME=discord_fetch
DISCORD_API_BASE=https://discord.com/api/v10
ALLOWED_GUILD_IDS=
MAX_THREADS_PER_CALL=100
MAX_MESSAGES_PER_CALL=200
ENABLE_SQLITE_CACHE=false
SQLITE_PATH=.data/discord-fetch-mcp.sqlite
LOG_LEVEL=info
EXPORT_DEFAULT_MESSAGE_LIMIT=200
