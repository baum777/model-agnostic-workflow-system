{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory/schemas/memory-entry.schema.json",
  "title": "Memory Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "createdAt",
    "updatedAt",
    "scope",
    "source",
    "writer",
    "confidence",
    "ttl",
    "provenance",
    "content",
    "policy",
    "promotion"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^mem_[a-zA-Z0-9_.:-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "enum": ["runtime", "project", "operator", "decision-candidate"]
    },
    "source": {
      "type": "string",
      "enum": ["runtime-run", "handoff", "manual-note", "validation", "commit"]
    },
    "writer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "agent", "runtime"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["observed", "validated", "inferred", "candidate"]
    },
    "ttl": {
      "type": "string",
      "enum": ["session", "30d", "durable-candidate"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "runId": {
          "type": ["string", "null"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": ["string", "null"]
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretChecked", "scopeChecked", "promotionRequired"],
      "properties": {
        "secretChecked": {
          "type": "boolean"
        },
        "scopeChecked": {
          "type": "boolean"
        },
        "promotionRequired": {
          "type": "boolean"
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "target", "reviewedBy", "reviewedAt"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["none", "candidate", "accepted", "rejected"]
        },
        "target": {
          "type": ["string", "null"]
        },
        "reviewedBy": {
          "type": ["string", "null"]
        },
        "reviewedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}
