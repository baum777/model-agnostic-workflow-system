{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory/schemas/memory-promotion.schema.json",
  "title": "Memory Promotion Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["memoryId", "target", "reviewedBy", "decision", "reviewedAt"],
  "properties": {
    "memoryId": {
      "type": "string",
      "pattern": "^mem_[a-zA-Z0-9_.:-]+$"
    },
    "target": {
      "type": "string",
      "enum": ["SOT.md", "DECISIONS.md", "MEMORY.md", "docs/*", "core/contracts/*"]
    },
    "reviewedBy": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["accepted", "rejected"]
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
