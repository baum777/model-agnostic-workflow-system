{
  "id": "secret-boundary-tool-contracts",
  "kind": "secret-boundary",
  "target": {
    "name": "validate-secret-boundaries"
  },
  "cases": [
    {
      "id": "secret-tool-valid",
      "caseType": "tool-contract",
      "expectedPass": true,
      "sample": {
        "requires_secret": true,
        "secret_classes": ["B"],
        "credential_binding": "server-only",
        "raw_secret_exposure": "forbidden",
        "model_visible": false,
        "secret_scope": "environment-validation",
        "environment_scope": ["staging"],
        "access_level": "read",
        "short_lived_preferred": true,
        "fallback_context_policy": "re-minimize",
        "trace_redaction": "required",
        "memory_persistence": "forbidden"
      }
    },
    {
      "id": "secret-tool-invalid",
      "caseType": "tool-contract",
      "expectedPass": false,
      "sample": {
        "requires_secret": true,
        "secret_classes": ["B"],
        "credential_binding": "server-only",
        "raw_secret_exposure": "allowed",
        "model_visible": true,
        "secret_scope": "environment-validation",
        "environment_scope": ["staging"],
        "access_level": "read",
        "short_lived_preferred": true,
        "fallback_context_policy": "re-minimize",
        "trace_redaction": "required",
        "memory_persistence": "forbidden"
      }
    }
  ]
}
