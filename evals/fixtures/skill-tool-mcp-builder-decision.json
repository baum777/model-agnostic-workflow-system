      "observedDecisionOutput": "{\"decision\":\"new MCP surface\",\"confidence\":\"medium\",\"reasoning_basis\":\"remote_protocol_boundary\",\"tie_break_rule\":\"none\",\"recommended_repo_action\":\"create_mcp_surface\",\"placement\":\"external MCP boundary\",\"followup_required\":true,\"reject_reason\":null}"
    },
    {
      "id": "surface-decision-04",
      "class": "negative",
      "request": "I am not sure what I need yet, but maybe make something for workflow stuff.",
      "context": "The request is vague, one-off, and does not justify a reusable surface.",
      "expectedDecision": "no justified reusable surface",
      "expectedDecisionPacket": {
        "decision": "no justified reusable surface",
        "confidence": "low",
        "reasoning_basis": "insufficient_evidence",
        "tie_break_rule": "fail_closed_on_missing_evidence",
        "recommended_repo_action": "reject_new_surface",
        "placement": "none",
        "followup_required": false,
        "reject_reason": "Request is too vague to justify a reusable surface."
      },
      "observedDecisionOutput": "{\"decision\":\"no justified reusable surface\",\"confidence\":\"low\",\"reasoning_basis\":\"insufficient_evidence\",\"tie_break_rule\":\"fail_closed_on_missing_evidence\",\"recommended_repo_action\":\"reject_new_surface\",\"placement\":\"none\",\"followup_required\":false,\"reject_reason\":\"Request is too vague to justify a reusable surface.\"}"
    },
    {
