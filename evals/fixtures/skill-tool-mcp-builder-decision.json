        "tie_break_rule": "prefer_extension_over_creation",
        "recommended_repo_action": "extend_existing_surface",
        "placement": "canonical/shared-core",
        "followup_required": true,
        "reject_reason": null
      },
      "observedDecisionOutput": "{\"decision\":\"extend existing surface\",\"confidence\":\"medium\",\"reasoning_basis\":\"nearest_existing_coverage\",\"tie_break_rule\":\"prefer_extension_over_creation\",\"recommended_repo_action\":\"extend_existing_surface\",\"placement\":\"canonical/shared-core\",\"followup_required\":true,\"reject_reason\":null}"
    },
    {
      "id": "surface-decision-07",
      "class": "borderline",
      "request": "Create a helper for repo structure and diff summarization, but only if it can be absorbed by the current scanner and diff explainer surfaces.",
      "context": "The request is ambiguous, but the nearest coverage already exists and should be extended rather than duplicated.",
      "expectedDecision": "extend existing surface",
      "expectedDecisionPacket": {
        "decision": "extend existing surface",
        "confidence": "medium",
        "reasoning_basis": "nearest_existing_coverage",
        "tie_break_rule": "prefer_extension_over_creation",
        "recommended_repo_action": "extend_existing_surface",
        "placement": "canonical/shared-core",
        "followup_required": true,
