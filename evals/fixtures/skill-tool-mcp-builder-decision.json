      "observedDecisionOutput": "{\"decision\":\"router/contracts/docs-only change\",\"confidence\":\"medium\",\"reasoning_basis\":\"authority_or_metadata_only\",\"tie_break_rule\":\"prefer_metadata_or_authority_only\",\"recommended_repo_action\":\"update_router_contracts_docs\",\"placement\":\"docs/router/contracts\",\"followup_required\":true,\"reject_reason\":null}"
    },
