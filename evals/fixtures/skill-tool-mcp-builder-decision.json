{
  "id": "skill-tool-mcp-builder-decision",
  "kind": "surface-decision",
  "blocking": true,
  "target": {
    "name": "skill-tool-mcp-builder"
  },
  "expectations": {
    "categories": [
      "new skill",
      "new tool",
      "new MCP surface",
      "extend existing surface",
      "router/contracts/docs-only change",
      "no justified reusable surface"
    ],
    "minimumCases": {
      "positive": 3,
      "negative": 2,
      "borderline": 2
    }
  },
  "cases": [
    {
      "id": "surface-decision-01",
      "class": "positive",
      "request": "Create a reusable workflow that turns loose repo-intake notes into a handoff packet for another agent.",
      "context": "Repeated operator task with stable output headings and explainable steps, but no existing narrow skill covers the exact workflow.",
      "expectedDecision": "new skill",
      "expectedDecisionPacket": {
        "decision": "new skill",
        "confidence": "high",
        "reasoning_basis": "repeatable_workflow",
        "tie_break_rule": "none",
        "recommended_repo_action": "create_skill",
        "placement": "canonical/shared-core",
        "followup_required": true,
        "reject_reason": null
      },
      "observedDecisionOutput": "{\"decision\":\"new skill\",\"confidence\":\"high\",\"reasoning_basis\":\"repeatable_workflow\",\"tie_break_rule\":\"none\",\"recommended_repo_action\":\"create_skill\",\"placement\":\"canonical/shared-core\",\"followup_required\":true,\"reject_reason\":null}"
    },
    {
      "id": "surface-decision-02",
      "class": "positive",
      "request": "Build a deterministic script that compares the generated registry snapshot against the committed one and fails on drift.",
      "context": "The request is executable and check-like, with explicit inputs and outputs.",
      "expectedDecision": "new tool",
      "expectedDecisionPacket": {
        "decision": "new tool",
        "confidence": "high",
        "reasoning_basis": "deterministic_tooling",
        "tie_break_rule": "none",
        "recommended_repo_action": "create_tool",
        "placement": "canonical/shared-core",
        "followup_required": true,
        "reject_reason": null
      },
      "observedDecisionOutput": "{\"decision\":\"new tool\",\"confidence\":\"high\",\"reasoning_basis\":\"deterministic_tooling\",\"tie_break_rule\":\"none\",\"recommended_repo_action\":\"create_tool\",\"placement\":\"canonical/shared-core\",\"followup_required\":true,\"reject_reason\":null}"
    },
    {
      "id": "surface-decision-03",
      "class": "positive",
      "request": "Expose an authenticated remote service that lets another repo query canonical state and invoke approved actions.",
      "context": "The request needs transport, auth, and a remote tool boundary rather than a local workflow skill.",
      "expectedDecision": "new MCP surface",
      "expectedDecisionPacket": {
        "decision": "new MCP surface",
        "confidence": "medium",
        "reasoning_basis": "remote_protocol_boundary",
        "tie_break_rule": "none",
        "recommended_repo_action": "create_mcp_surface",
        "placement": "external MCP boundary",
        "followup_required": true,
        "reject_reason": null
